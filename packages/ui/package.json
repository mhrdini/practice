  },
  "devDependencies": {
    "@tailwindcss/cli": "catalog:tailwindcss",
    "@tailwindcss/postcss": "catalog:tailwindcss",
    "autoprefixer": "catalog:tailwindcss",
    "eslint": "catalog:",
    "eslint-plugin-format": "catalog:",
    "tailwindcss": "catalog:tailwindcss",
    "typescript": "catalog:"
  }
}

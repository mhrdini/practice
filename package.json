{
  "name": "practice",
  "private": true,
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "ui": "turbo run ui",
    "postui": "pnpm run barrels",
    "ui:react": "turbo run ui:react",
    "ui:vue": "turbo run ui:vue",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "commit": "printf '' > .git/COMMIT_EDITMSG && git-cz",
    "barrels": "node scripts/generate-barrels.js"
  },
  "peerDependencies": {
    "inquirer": "catalog:"
  },
  "validate-branch-name": {
    "pattern": "^(main){1}$|^(feat|fix|hotfix|release|chore)/.+$",
    "errorMsg": "Invalid branch name \n Ex. [master, develop, feature/feature-info, fix/112-fix-info, hotfix/112-hotfix-info, release/1.0.0, chores/chores-info]"
  },
  "dependencies": {
    "dotenv-expand": "catalog:"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@apps/react": "workspace:*",
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@commitlint/cz-commitlint": "catalog:",
    "barrelsby": "catalog:",
    "commitizen": "catalog:",
    "dotenv": "catalog:",
    "dotenv-cli": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-format": "catalog:",
    "husky": "catalog:",
    "lint-staged": "catalog:",
    "prettier": "catalog:",
    "tsx": "catalog:",
    "turbo": "catalog:",
    "validate-branch-name": "catalog:"
  },
  "lint-staged": {
    "**/*.{js,ts,jsx,tsx,css,html,vue}": [
      "eslint --fix"
    ]
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  }
}
